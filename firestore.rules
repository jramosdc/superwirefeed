rules_version = '2';

// SuperWire Firestore rules.
// Public content (feeds, posts, reviews, comments) is world-readable so the
// marketplace can be browsed without an account. Writes are restricted to the
// owning user. Privileged docs (purchases) are written only by the Admin SDK
// via the Stripe webhook — clients can read their own but never create them.
service cloud.firestore {
  function signedIn() {
    return request.auth != null;
  }
  function isUser(uid) {
    return signedIn() && request.auth.uid == uid;
  }

  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if true;
      allow create, update: if isUser(uid);
      allow delete: if isUser(uid);
    }

    match /feeds/{feedId} {
      // feedId === owner uid
      allow read: if true;
      allow create, update, delete: if isUser(feedId);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if signedIn()
                    && request.resource.data.owner.uid == request.auth.uid;
      allow update, delete: if signedIn()
                    && resource.data.owner.uid == request.auth.uid;
    }

    match /purchases/{purchaseId} {
      // Only the buyer can read their receipt; only the server (Admin SDK,
      // which bypasses these rules) ever writes them.
      allow read: if signedIn() && resource.data.buyerUid == request.auth.uid;
      allow write: if false;
    }

    match /reviews/{reviewId} {
      // Public to read. Created only via the server (/api/reviews) so the
      // seller's rating aggregate is updated transactionally.
      allow read: if true;
      allow write: if false;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if signedIn()
                    && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if signedIn()
                    && resource.data.authorUid == request.auth.uid;
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if signedIn()
                    && request.resource.data.followerUid == request.auth.uid;
      allow delete: if signedIn()
                    && resource.data.followerUid == request.auth.uid;
    }
  }
}
