# Copy this file to .env.local and fill in real values. NEVER put secrets here.

# ---- Firebase client SDK (safe to expose; used in the browser) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Point the client SDK at the local emulator suite during development.
# Set to "true" when running `npm run emulators`.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# ---- Firebase Admin SDK (server only; NEVER expose) ----
# Either paste the full service-account JSON as a single-line string in
# FIREBASE_SERVICE_ACCOUNT_KEY, or point GOOGLE_APPLICATION_CREDENTIALS at a file.
FIREBASE_SERVICE_ACCOUNT_KEY=
GOOGLE_APPLICATION_CREDENTIALS="./service-account-key.json"
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# ---- Stripe (server only, except the publishable key) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
