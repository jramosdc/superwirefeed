{
  "name": "superwire",
  "version": "1.0.0",
  "private": true,
  "description": "SuperWire — a marketplace for user-created wire services (Next.js + Firebase rebuild)",
  "engines": {
    "node": ">=20 <24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "emulators": "firebase emulators:start",
    "seed": "node scripts/seed.mjs",
    "loadtest": "node scripts/loadtest.mjs",
    "loadtest:cleanup": "node scripts/loadtest.mjs --cleanup",
    "audit": "node scripts/audit.mjs",
    "test:rules": "firebase emulators:exec --only firestore,storage \"vitest run rules\""
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "firebase": "^11.3.0",
    "firebase-admin": "^13.0.2",
    "stripe": "^17.5.0",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "papaparse": "^5.4.1",
    "react-easy-crop": "^5.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/papaparse": "^5.3.15",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.5.1",
    "@firebase/rules-unit-testing": "^4.0.1",
    "vitest": "^3.0.4"
  }
}
