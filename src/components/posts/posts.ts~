		this.as.deletePost(this.deletePostID);
	}

	voteUp() {
		this.as.voteUp(this.UserID);
	}

	voteDown() {
		this.as.voteDown(this.UserID);
	}

	returnMoment(timestamp) {
		if (timestamp) {
			return moment().to(timestamp);
		} else {
			return ''
		}
