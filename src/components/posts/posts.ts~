@Pipe({
	name: 'searchPostTitle'
})
class SearchPostTitlePipe implements PipeTransform {
	transform(values, args?) {
        let [filter] = args;
        return filter ? values.filter(value=> value.title.toLocaleLowerCase().lastIndexOf(filter) != -1) : values;
	}
}


